int insert(BSTNode **root, Cat *cat) {
    // No root tree 
    if (*root == NULL) {
        BSTNode *n = createNode();
        n->cat = cat;
        n->subtree_size = 1;

        *root = n;

        return 0;
    }


    // Cat Exists
    BSTNode *n = NULL;
    n = searchForCat(*root, cat->name);

    if (n != NULL) {
        int c1 = 0;
        int c2 = 0;

        // Check if need to replace
        for (int i = 0; i < NUM_TRAITS; i++) {
            if (n->cat->traits[i] == 1) c1++;
            if (cat->traits[i] == 1) c2++;
        }

        if (c1 < c2) {
            freeCat(n->cat);
            n->cat = cat;
            return REPLACED;
        } else {
            return EXISTS;
        }
    }

    
    // Normal Insertion
   int depth = insertRec(*root, cat); 

    return depth;
}


int insertRec(BSTNode *root, Cat *cat) {
    root->subtree_size++;

    int depth = 0;

    if (strcmp(root->cat->name, cat->name) < 0) {
        if (root->right != NULL) {
            depth = insertRec(root->right, cat) + 1;
        } else {
            BSTNode *n = createNode();
            n->cat = cat;
            n->subtree_size++;
            root->right = n;
            return 1;
        }
    } else {
        if (root->left != NULL) {
            depth = insertRec(root->left, cat) + 1;
        } else {
            BSTNode *n = createNode();
            n->cat = cat;
            n->subtree_size++;
            root->left = n;
            return 1;
        }
    }

    return depth;
}


BSTNode *searchForCat(BSTNode *root, char *name) {
    if (root == NULL || name == NULL) return NULL; 
    
    dprintf(": %s\n", root->cat->name);

    BSTNode *n = NULL;

    if (strcmp(root->cat->name, name) == 0) {
        return root;
    } else if (strcmp(root->cat->name, name) > 0) {
        if (root->right != NULL) dprintf("-> ");
        n = searchForCat(root->right, name);
    } else {
        if (root->left != NULL) dprintf("<- ");
        n = searchForCat(root->left, name);
    }

    return n;

}


BSTNode *searchForCatParent(BSTNode *root, char *name) {
    if (root == NULL || name == NULL) return NULL; 

    if (strcmp(root->cat->name, name) == 0) dprintf("No parent, root!\n");
    if (strcmp(root->cat->name, name) == 0) return NULL;

    dprintf(": %s\n", root->cat->name);

    BSTNode *n = NULL;

    if (strcmp(root->cat->name, name) < 0) {
        if (root->right != NULL && strcmp(root->right->cat->name, name) == 0) {
            return root; 
        } else {
            dprintf("-> ");
            n = searchForCatParent(root->right, name);
        }
    } else {
        if (root->left != NULL && strcmp(root->left->cat->name, name) == 0) {
            return root; 
        } else {
            dprintf("<- ");
            n = searchForCatParent(root->left, name);
        }
    }

    return n;
}


void pruneSubtreeSize(BSTNode *root, char *name) {
    if (root == NULL || name == NULL) return; 

    root->subtree_size--;
    
    dprintf(": %s\n", root->cat->name);

    if (strcmp(root->cat->name, name) == 0) {
        return;
    } else if (strcmp(root->cat->name, name) < 0) {
        if (root->right != NULL) dprintf("-> ");
        pruneSubtreeSize(root->right, name);
    } else {
        if (root->left != NULL) dprintf("<- ");
        pruneSubtreeSize(root->left, name);
    }

    return;

}


BSTNode *findSuccessor(BSTNode *n) {
    if (n->left == NULL) return n;

    BSTNode *s = NULL;

    s = findSuccessor(n->left);

    return s;
}


void walk(BSTNode *root, int depth) {
    if (root == NULL) {
        dprintf("Empty Tree!\n");
        return;
    }

    if (root->left == NULL && root->right == NULL) {
        dprintf("%d:%s(%d)]", depth, root->cat->name, root->subtree_size);
        return;
    }
    
    dprintf("%d:%s(%d)", depth, root->cat->name, root->subtree_size);
    dprintf(" [");

    if (root->left != NULL) {
        dprintf(" / ");
        walk(root->left, depth + 1);
    } 

    if (root->right != NULL) {
        dprintf(" \\ ");
        walk(root->right, depth + 1);
    } 

    return;
}


