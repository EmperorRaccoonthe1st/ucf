void delete(BSTNode **root, BSTNode *n) {
    if (*root == NULL || n == NULL) return; 

    dprintf("Deleting: %s\n", n->cat->name); 

    //when deleting root
    if (*root == n) {
        if (n->left == NULL && n->right == NULL) {
            dprintf("Single Node Tree!\n");
            deleteNode(n);
            *root = NULL;
            return;
        }

        if (n->left == NULL && n->right != NULL) {
            dprintf("Root has one right Child!\n");
            *root = n->right;
            deleteNode(n);
            return;
        }

        if (n->left != NULL && n->right == NULL) {
            dprintf("Root has one left Child!\n");
            *root = n->left;
            deleteNode(n);
            return;
        }

        if (n->left != NULL && n->right != NULL) {
            BSTNode *successor = findSuccessor(n->right);
            dprintf("Root replaced by Successor: %s!\n", successor->cat->name);
            
            Cat *tmp = malloc(sizeof(Cat));
            cpyCat(tmp, successor->cat);

            delete(root, successor);

            n->cat = tmp; 

            return;
        } 
    }

    BSTNode *parent = searchForCatParent(*root, n->cat->name);


    // finding relation to parent
    int dir; // 0 = left and 1 = right
    if (strcmp(parent->cat->name, n->cat->name) < 0) {
        dir = 1;    
    } else {
        dir = 0;    
    }


    // No children 
    if (n->left == NULL && n->right == NULL) {
        dprintf("%s is childless!\n", n->cat->name);
        pruneSubtreeSize(*root, n->cat->name);

        if (dir) {
            parent->right = NULL;
        } else {
            parent->left = NULL;
        }
        
        deleteNode(n);
        return;
    }

    if (n->left == NULL && n->right != NULL) {
        dprintf("Node has one right child\n");
        pruneSubtreeSize(*root, n->cat->name);
        if (dir) {
            parent->right = n->right;
        } else {
            parent->left = n->right;
        }

        deleteNode(n);
        return;
    }

    if (n->left != NULL && n->right == NULL) {
        dprintf("Node has one left child\n");
        pruneSubtreeSize(*root, n->cat->name);
        if (dir) {
            parent->right = n->left;
        } else {
            parent->left = n->left;
        }

        deleteNode(n);
        return;
    }

    if (n->left != NULL && n->right != NULL) {
        dprintf("Node replaced by Successor!\n");
        BSTNode *successor = findSuccessor(n->right);
        pruneSubtreeSize(*root, successor->cat->name);

        Cat *tmp = malloc(sizeof(Cat));
        cpyCat(tmp, successor->cat);

        delete(root, successor);

        n->cat = tmp; 

        delete(root, successor);
        return;
    } 

}


BSTNode *findKth(BSTNode *root, int k) {
    if (root == NULL) return NULL;

    int lSize = 0;

    if (root->left != NULL) {
        lSize = root->left->subtree_size;
    } else {
        lSize = 0;
    }


    if ( k <= lSize) {
        return findKth(root->left, k);
    } else if (k == lSize + 1) {
        return root;
    } else { 
        return findKth(root->right, k - (lSize + 1)); 
    }
    
}
