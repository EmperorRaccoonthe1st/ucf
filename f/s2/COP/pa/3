Cat *readCat(FILE *ifile) {
    Cat *c = malloc(sizeof(Cat));
    
    char buff[MAX_LEN];
    fscanf(ifile, "%s", buff);
    
    char *name = malloc((strlen(buff) + 1) * sizeof(char));
    strcpy(name, buff);
    c->name = name;

    char breedBuff[MAX_LEN];
    fscanf(ifile, "%s", breedBuff);
    
    char *breed = malloc((strlen(breedBuff) + 1) * sizeof(char));
    strcpy(name, breedBuff);
    c->breed = breed;

    for (int i = 0; i < NUM_TRAITS; i++) {
        fscanf(ifile, "%d", &c->traits[i]);
    }
    
    return c;
}


void freeCat(Cat *c) {
    free(c->name);
    free(c->breed);

    free(c);
}


BSTNode *createNode() {
    BSTNode *n = malloc(sizeof(BSTNode));

    n->left = NULL;
    n->right = NULL;

    n->cat = NULL;

    n->subtree_size = 0;

    return n;
}


void freeNode(BSTNode *n) {
    free(n);
}
    

void query1(FILE *ifile, BSTNode *root) {
    Cat *c = freeCat(ifile);     

    int depth = insert(root, c);

    if (depth == EXISTS) {
        free(c);
    } else if (depth == REPLACED) {
        printf("Replaced\n");
    } else {
        printf("Insert: %d\n", depth);
    }

}


int insert(BSTNode *root, Cat *cat) {

    // No root tree case;
    if (root == NULL) {
        BSTNode *n = createNode();
        n->cat = cat;
        n->subtree_size = 1;

        *root = n;

        return 0;
    }

}


